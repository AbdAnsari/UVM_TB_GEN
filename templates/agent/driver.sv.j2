//============================================================
// Driver : {{ ag.name }}_driver
// ── ADD your drive logic in drive_transfer() below ──
//============================================================

class {{ ag.name }}_driver extends uvm_driver #({{ ag.name }}_item);

  `uvm_component_utils({{ ag.name }}_driver)

  virtual {{ ag.name }}_if.DRV_MP vif;
  {{ ag.name }}_agent_cfg         cfg;
  {{ ag.name }}_item              item;

  function new(string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  // ---------------------------------------------------------
  // Build Phase
  // ---------------------------------------------------------
  function void build_phase(uvm_phase phase);
    super.build_phase(phase);
    if (!uvm_config_db#({{ ag.name }}_agent_cfg)::get(this, "", "cfg", cfg))
      `uvm_fatal("{{ ag.name | upper }}_DRV", "Cannot get {{ ag.name }}_agent_cfg")
    if (cfg.vif_drv == null)
      `uvm_fatal("{{ ag.name | upper }}_DRV", "Virtual Interface (vif_drv) is NULL in config!")
    vif = cfg.vif_drv;
  endfunction

  // ---------------------------------------------------------
  // Run Phase
  // ---------------------------------------------------------
  task run_phase(uvm_phase phase);
    `uvm_info("{{ ag.name | upper }}_DRV", "Driver started", UVM_LOW)
    reset_driver();
    @(vif.drv_cb);
    `uvm_info("{{ ag.name | upper }}_DRV", "Reset complete, driver ready", UVM_LOW)

    forever begin
      if (!vif.rst_n) break; 
      seq_item_port.get_next_item(item);

      fork
        begin : DRIVE_THREAD
          drive_transfer(item);
        end

        begin : RESET_WATCHDOG
          wait (vif.rst_n == 0);
        end
      join_any

      if (vif.rst_n) begin
        seq_item_port.item_done();
        wait fork; 
        disable fork; 
        item = null;
      end
      
      else begin
          disable fork;
          if (item != null) begin
            `uvm_info("{{ ag.name | upper }}_DRV", "Reset abort: Clearing sequencer", UVM_LOW)
            seq_item_port.item_done();
            item = null;
          end
          handle_reset();
      end
    end
  endtask

  // ---------------------------------------------------------
  // Reset Driver
  // ─────────────────────────────────────────────────────────
  // TODO: Drive all output signals to safe idle values
  // ---------------------------------------------------------
  task reset_driver();
    `uvm_info("{{ ag.name | upper }}_DRV", "Reset started", UVM_LOW)
    // TODO: Zero-out all driven signals
    // Example:
{% for p in ag.ports %}
{% if p.direction == "input" %}
    // vif.drv_cb.{{ p.name }} <= '0;
{% endif %}
{% endfor %}
    wait(vif.rst_n);
    `uvm_info("{{ ag.name | upper }}_DRV", "Reset done", UVM_LOW)
  endtask

  // ---------------------------------------------------------
  // Drive Transfer
  // ─────────────────────────────────────────────────────────
  // TODO: Implement your protocol handshake here
  // ---------------------------------------------------------
  task drive_transfer({{ ag.name }}_item item);
    `uvm_info("{{ ag.name | upper }}_DRV",
      $sformatf("Driving item: %s", item.convert2string()),
      UVM_LOW)

    // TODO: Drive signals from item fields
    // TODO: Wait for handshake / ack
    @(vif.drv_cb);
    `uvm_info("{{ ag.name | upper }}_DRV", "Transaction complete", UVM_LOW)
  endtask

  // ---------------------------------------------------------
  // Reset Recovery
  // ---------------------------------------------------------
  task handle_reset();
    // TODO: Drive idle values immediately on reset
    wait (vif.rst_n == 1);
    @(vif.drv_cb);
    `uvm_info("{{ ag.name | upper }}_DRV", "Reset recovery complete", UVM_LOW)
  endtask

endclass
