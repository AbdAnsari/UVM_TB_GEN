//============================================================
// Config : env_cfg
//============================================================

class env_cfg extends uvm_object;

  `uvm_object_utils(env_cfg)

{% for ag in agents %}
  {{ ag.name }}_agent_cfg  {{ ag.name }}_cfg;
{% endfor %}

  function new(string name = "env_cfg");
    super.new(name);
{% for ag in agents %}
    {{ ag.name }}_cfg = {{ ag.name }}_agent_cfg::type_id::create("{{ ag.name }}_cfg");
{% endfor %}
  endfunction

endclass
